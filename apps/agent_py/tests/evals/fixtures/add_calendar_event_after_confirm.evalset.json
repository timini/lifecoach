{
  "eval_set_id": "add_calendar_event_after_confirm",
  "name": "Calendar add — confirm then insert",
  "description": "User asks to add a specific event. Agent must (a) confirm via ask_single_choice_question first, then (b) on 'Yes' call add_calendar_event with structured args (summary/start/end). Catches the 'never act on a write without an explicit yes' boundary.",
  "eval_cases": [
    {
      "eval_id": "case_01_lunch_with_sarah",
      "session_input": {
        "app_name": "lifecoach",
        "user_id": "test-user-calendar-add",
        "state": {
          "_lifecoach_user_state": "workspace_connected",
          "_lifecoach_now": "2026-05-12T13:00:00+01:00"
        }
      },
      "conversation": [
        {
          "user_content": {
            "parts": [{ "text": "add lunch with Sarah on Tuesday at 12:30 to my calendar" }],
            "role": "user"
          },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "ask_single_choice_question",
                "args": {
                  "question": "Add 'Lunch with Sarah, Tue 12:30' to your calendar?",
                  "options": ["Yes", "Skip"]
                }
              }
            ]
          }
        },
        {
          "user_content": { "parts": [{ "text": "Yes" }], "role": "user" },
          "intermediate_data": {
            "tool_uses": [
              {
                "name": "add_calendar_event",
                "args": {
                  "summary": "Lunch with Sarah",
                  "start": "2026-05-19T12:30:00+01:00",
                  "end": "2026-05-19T13:30:00+01:00"
                }
              }
            ]
          }
        }
      ]
    }
  ]
}
