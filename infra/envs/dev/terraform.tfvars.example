# Example values. Your real terraform.tfvars is generated by
# infra/bootstrap/bootstrap.sh and is gitignored.

project_id      = "lifecoach-dev"
region          = "us-central1"
org_id          = "59273835578"
billing_account = "00F211-1C6C40-2306DA"
environment     = "dev"

# Optional Sentry DSN. Empty disables telemetry (SDKs no-op).
# sentry_dsn = "https://<key>@<org>.ingest.sentry.io/<project>"

# Optional Notion OAuth (public integration at notion.so/my-integrations).
# Leave both empty to disable the Notion sub-agent in this env. Client ID
# is public (baked into the web bundle as NEXT_PUBLIC_NOTION_OAUTH_CLIENT_ID);
# secret is stored in Secret Manager.
# notion_client_id     = "<your-public-client-id>"
# notion_client_secret = "<your-client-secret>"
