{
  "name": "lifecoach",
  "version": "0.0.0",
  "private": true,
  "description": "AI life coaching app — Next.js web + Google ADK agent monorepo",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "22.9.0",
    "lefthook": "1.8.4",
    "turbo": "2.3.0",
    "typescript": "5.7.2",
    "vitest": "3.2.4",
    "@vitest/coverage-v8": "3.2.4"
  }
}
