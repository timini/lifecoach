{
  "eval_set_id": "find_workspace_calendar_list",
  "agent_module": "tests.evals.eval_find_workspace_agent",
  "name": "Find Workspace sub-agent lists calendars for calendar ID requests",
  "description": "Direct calendar-list / calendar-ID requests should call list_calendars and return the Family calendar ID, rather than searching Gmail or listing events.",
  "eval_cases": [
    {
      "eval_id": "case_01_list_google_calendars_find_family_id",
      "session_input": {
        "app_name": "find_workspace",
        "user_id": "eval-find-workspace-uid",
        "state": {}
      },
      "conversation": [
        {
          "user_content": {
            "parts": [
              { "text": "{\"query\":\"list my Google calendars and find the family calendar ID\"}" }
            ],
            "role": "user"
          },
          "intermediate_data": {
            "tool_uses": [{ "name": "list_calendars", "args": {} }]
          },
          "final_response": {
            "parts": [{ "text": "family_123@group.calendar.google.com" }],
            "role": "model"
          }
        }
      ]
    }
  ]
}
