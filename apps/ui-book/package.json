{
  "name": "@lifecoach/ui-book",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Storybook for @lifecoach/ui — atomic-design design system",
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "storybook build -o storybook-static",
    "build-storybook": "storybook build -o storybook-static",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo storybook-static *.tsbuildinfo coverage"
  },
  "dependencies": {
    "@lifecoach/ui": "workspace:*"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-vitest": "9.1.20",
    "@storybook/nextjs-vite": "9.1.20",
    "@tailwindcss/vite": "4.0.0-beta.6",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "3.2.4",
    "next": "15.0.3",
    "playwright": "1.49.1",
    "react": "19.0.0-rc-66855b96-20241106",
    "react-dom": "19.0.0-rc-66855b96-20241106",
    "storybook": "9.1.20",
    "tailwindcss": "4.0.0-beta.6",
    "typescript": "5.7.2",
    "vite": "5.4.10",
    "vitest": "3.2.4"
  }
}
