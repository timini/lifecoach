{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "composite": false,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": ["playwright.config.ts", "e2e/**/*.ts"],
  "exclude": ["node_modules", "test-results", "playwright-report"]
}
