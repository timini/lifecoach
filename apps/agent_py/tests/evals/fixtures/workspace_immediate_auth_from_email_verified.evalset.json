{
  "eval_set_id": "workspace_immediate_auth_from_email_verified",
  "agent_module": "tests.evals.eval_email_verified_agent",
  "name": "email_verified user asks for a workspace op → auth_user on turn 1",
  "description": "Sibling of `workspace_immediate_auth_from_anonymous`. Different state directive (their progress is already saved, so the framing isn't 'save progress' it's 'unlock workspace'), same TRIGGER routing to `auth_user({mode:\"google\"})` on turn 1. Separate fixture because the eval framework binds one agent_module per fixture, and the per-state agents have different system prompts.",
  "eval_cases": [
    {
      "eval_id": "case_01_emailver_triage_my_emails",
      "session_input": {
        "app_name": "lifecoach",
        "user_id": "test-user-emailver-triage",
        "state": {
          "_lifecoach_user_state": "email_verified",
          "_lifecoach_now": "2026-05-12T09:00:00+01:00"
        }
      },
      "conversation": [
        {
          "user_content": {
            "parts": [{ "text": "triage my emails" }],
            "role": "user"
          },
          "intermediate_data": {
            "tool_uses": [{ "name": "auth_user", "args": { "mode": "google" } }]
          }
        }
      ]
    },
    {
      "eval_id": "case_02_emailver_check_calendar",
      "session_input": {
        "app_name": "lifecoach",
        "user_id": "test-user-emailver-cal",
        "state": {
          "_lifecoach_user_state": "email_verified",
          "_lifecoach_now": "2026-05-12T09:00:00+01:00"
        }
      },
      "conversation": [
        {
          "user_content": {
            "parts": [{ "text": "what's on my calendar today?" }],
            "role": "user"
          },
          "intermediate_data": {
            "tool_uses": [{ "name": "auth_user", "args": { "mode": "google" } }]
          }
        }
      ]
    }
  ]
}
