# Local dev — copy to .env (gitignored) and fill in the values.

# --- GCP / Vertex ----------------------------------------------------------
GOOGLE_CLOUD_PROJECT=lifecoach-dev-zvb6d
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=1

# Vertex AI Agent Engine for Memory Bank — Terraform output (Phase 4 wires it).
# AGENT_ENGINE_ID=projects/.../locations/.../reasoningEngines/...

# --- Firebase --------------------------------------------------------------
# Application default credentials work locally if you've run
#   gcloud auth application-default login
# Otherwise point to a service account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# --- Sentry ----------------------------------------------------------------
# SENTRY_DSN=

# --- Eval mode -------------------------------------------------------------
# Set to "1" to opt into Tier-2 evals that hit real Gemini.
# LIFECOACH_EVAL_REAL_LLM=
